# Cloudflare Pages headers.
# The Magic Dust lessons run Python (Pyodide) in a worker and block on
# SharedArrayBuffer, which requires cross-origin isolation. 'credentialless'
# lets the Pyodide/Monaco/MediaPipe CDN assets load without CORP headers.
/magic-dust/lessons/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
